# Port that the local loopback Express server listens on
PORT=3000

# Strict loopback Mongoose connection string for local MongoDB instances
MONGO_DB_URI=mongodb://127.0.0.1:27017/tech-tools

# Production target node execution environment ("production" or "development")
NODE_ENV=production

# Granularity of Pino logger outputs ("trace", "debug", "info", "warn", "error")
LOG_LEVEL=info
